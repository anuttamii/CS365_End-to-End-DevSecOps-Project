pipeline {
    agent any
    
    tools {
        nodejs 'nodejs'
    }
    
    environment {
        IMAGE_NAME = "sittiyaa/tetrisv1"
        REPO_URL   = "github.com/anuttamii/CS365_End-to-End-DevSecOps-Project.git"
        SONAR_NAME = "sonar-scanner" 
    }
    
    stages {
        stage('Cleaning Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout from Git') {
            steps {
                git branch: 'main', 
                    url: "https://${env.REPO_URL}"
            }
        }

        stage('Sonarqube Analysis') {
            steps {
                dir('Tetris-V1') {
                    // 1. ดึง Path ของเครื่องมือ sonar-scanner ที่เราตั้งไว้ใน Tools
                    script {
                        def scannerHome = tool 'sonar-scanner' 
                        
                        // 2. เรียกใช้ Environment ของ Sonar Server
                        withSonarQubeEnv('sonar-scanner') { 
                            sh "npm install && npm run build || true"
                            
                            // 3. ใช้ Path เต็มในการรันคำสั่ง
                            sh "${scannerHome}/bin/sonar-scanner -Dsonar.projectKey=Tetris-Project"
                        }
                    }
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('Tetris-V1') {
                    sh 'npm install'
                }
            }
        }

        stage('Trivy File Scan') {
            steps {
                dir('Tetris-V1') {
                    sh 'trivy fs . > trivyfs.txt || true'
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('Tetris-V1') {
                    sh "docker build -t ${IMAGE_NAME}:${BUILD_NUMBER} ."
                }
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker', 
                    usernameVariable: 'DOCKER_USER', 
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                        docker tag ${IMAGE_NAME}:${BUILD_NUMBER} ${IMAGE_NAME}:latest
                        docker push ${IMAGE_NAME}:${BUILD_NUMBER}
                        docker push ${IMAGE_NAME}:latest
                    '''
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh "trivy image ${IMAGE_NAME}:${BUILD_NUMBER} > trivyimage.txt || true"
            }
        }

        stage('Update Deployment File') {
            steps {
                dir('Manifest-file') {
                    withCredentials([usernamePassword(
                        credentialsId: 'github', 
                        usernameVariable: 'GH_USER', 
                        passwordVariable: 'GH_TOKEN'
                    )]) {
                        sh '''
                            git config user.email "anuttama.sae@dome.tu.ac.th"
                            git config user.name "anuttamii"
                            OLD_TAG=$(grep -oP '(?<=avian19/tetrisv1:)[^ ]+' deployment-service.yml || echo "latest")
                            sed -i "s|avian19/tetrisv1:${OLD_TAG}|avian19/tetrisv1:${BUILD_NUMBER}|g" deployment-service.yml

                            git add deployment-service.yml
                            if git diff --quiet && git diff --staged --quiet; then
                                echo "No changes to commit."
                            else
                                git commit -m "Update image to version ${BUILD_NUMBER} [skip ci]"
                                git push "https://${GH_USER}:${GH_TOKEN}@github.com/anuttamii/CS365_End-to-End-DevSecOps-Project.git" HEAD:main
                            fi
                        '''
                    }
                }
            }
        }
    }
    
    post {
        always {
            echo "Pipeline finished execution."
            sh 'docker image prune -f || true'
        }
        success {
            echo "Successfully deployed version ${BUILD_NUMBER}!"
        }
        failure {
            echo "Pipeline failed. Check SonarQube or Disk space."
        }
    }
}