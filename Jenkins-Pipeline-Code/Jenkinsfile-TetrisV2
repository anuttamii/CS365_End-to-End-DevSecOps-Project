pipeline {
    agent any
    
    tools {
        nodejs 'nodejs'
    }
    
    environment {
        IMAGE_NAME = "sittiyaa/tetrisv2"
        REPO_URL   = "github.com/anuttamii/CS365_End-to-End-DevSecOps-Project.git"
    }
    
    stages {
        stage('Cleaning Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout from Git') {
            steps {
                git branch: 'develop', 
                    url: "https://${env.REPO_URL}"
            }
        }

        stage('Sonarqube Analysis') {
            steps {
                dir('Tetris-V2') {
                    script {
                        def scannerHome = tool 'sonar-scanner' 
                        withSonarQubeEnv('sonar-scanner') { 
                            // รันแบบรวบรัด ไม่ต้องลง npm install ข้างนอก
                            sh "${scannerHome}/bin/sonar-scanner -Dsonar.projectKey=Tetris-Project"
                        }
                    }
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                dir('Tetris-V2') {
                    withCredentials([usernamePassword(
                        credentialsId: 'docker', 
                        usernameVariable: 'DOCKER_USER', 
                        passwordVariable: 'DOCKER_PASS'
                    )]) {
                        sh '''
                            docker build -t ${IMAGE_NAME}:${BUILD_NUMBER} .
                            docker tag ${IMAGE_NAME}:${BUILD_NUMBER} ${IMAGE_NAME}:latest
                            echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                            docker push ${IMAGE_NAME}:${BUILD_NUMBER}
                            docker push ${IMAGE_NAME}:latest
                        '''
                    }
                }
            }
        }

        stage('Update Deployment File') {
            steps {
                dir('Manifest-file') {
                    withCredentials([usernamePassword(
                        credentialsId: 'github', 
                        usernameVariable: 'GH_USER', 
                        passwordVariable: 'GH_TOKEN'
                    )]) {
                        sh '''
                            git config user.email "anuttama.sae@dome.tu.ac.th"
                            git config user.name "anuttamii"

                            # เปลี่ยนชื่อภาพและ Tag ให้เป็นปัจจุบัน
                            sed -i "s|avian19/tetrisv2:[^ ]*|${IMAGE_NAME}:${BUILD_NUMBER}|g" deployment-service.yml
                            sed -i "s|sittiyaa/tetrisv2:[^ ]*|${IMAGE_NAME}:${BUILD_NUMBER}|g" deployment-service.yml

                            # เจาะจงเฉพาะไฟล์ที่ต้องการ commit เท่านั้น
                            git add deployment-service.yml
                            
                            # ถ้ามีการเปลี่ยนแปลง ให้ commit และ push
                            if ! git diff --staged --quiet; then
                                git commit -m "Update image to version ${BUILD_NUMBER} [skip ci]"
                                git push "https://${GH_USER}:${GH_TOKEN}@github.com/anuttamii/CS365_End-to-End-DevSecOps-Project.git" HEAD:develop
                            else
                                echo "No changes detected in deployment-service.yml"
                            fi
                        '''
                    }
                }
            }
        }
    }
    
    post {
        always {
            echo "Pipeline finished execution."
            // ลบ Image ทิ้งเพื่อคืนพื้นที่ Disk ทันที
            sh "docker rmi ${IMAGE_NAME}:${BUILD_NUMBER} ${IMAGE_NAME}:latest || true"
            sh 'docker image prune -f || true'
        }
        success {
            echo "Successfully deployed version ${BUILD_NUMBER}!"
        }
        failure {
            echo "Pipeline failed. Check Git credentials or Disk space."
        }
    }
}